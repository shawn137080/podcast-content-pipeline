# ============================================================
# Podcast Pipeline — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=podcast
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_DB=podcast_pipeline

# ── n8n ─────────────────────────────────────────────────────
# URL for webhooks (update for your environment)
WEBHOOK_URL=http://localhost:5678

# n8n encryption key (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=change_me_generate_with_openssl_rand_hex_32

# Execution mode: "regular" for single-instance POC,
#                "queue" for production multi-worker
EXECUTIONS_MODE=regular

# ── Open Notebook ────────────────────────────────────────────
# REQUIRED: Change this to a secure random string
# Generate with: openssl rand -hex 32
OPEN_NOTEBOOK_ENCRYPTION_KEY=change_me_to_a_secure_random_string

# Open Notebook password (same as ENCRYPTION_KEY for dev)
OPEN_NOTEBOOK_PASSWORD=change_me_to_a_secure_random_string

# ── STT Provider (Deepgram default) ──────────────────────────
# Sign up at https://console.deepgram.com ($200 trial credit)
STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Optional: alternative providers
# Speechmatics - https://www.speechmatics.com (3,000 min/month free)
SPEECHMATICS_API_KEY=
# AssemblyAI - https://www.assemblyai.com (3 hours/month free)
ASSEMBLYAI_API_KEY=
# Gladia - https://gladia.io (10 hours/month free)
GLADIA_API_KEY=

# ── LLM Provider (MiniMax default) ───────────────────────────
# Sign up at https://platform.minimax.chat (Token Plan)
# IMPORTANT: Use https://api.minimax.io/v1 (not api.minimax.chat)
LLM_PROVIDER=minimax
MINIMAX_API_KEY=your_minimax_api_key_here

# Optional: alternative LLM providers (modify in config/llm_providers.json)
# Anthropic - https://console.anthropic.com
ANTHROPIC_API_KEY=
# OpenAI - https://platform.openai.com
OPENAI_API_KEY=
# Google Gemini - https://aistudio.google.com
GOOGLE_API_KEY=
# Groq - https://console.groq.com (free tier)
GROQ_API_KEY=

# ── Telegram ─────────────────────────────────────────────────
# Create bot via @BotFather, get your chat_id via getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Ollama (optional, for local LLM) ────────────────────────
# Uncomment if using Ollama instead of cloud LLM
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:70b

# ── Docker Network ────────────────────────────────────────────
# Default network name for internal communication
COMPOSE_PROJECT_NAME=podcast-pipeline
